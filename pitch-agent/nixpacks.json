{
  "phases": {
    "setup": {
      "aptPkgs": [
        "chromium",
        "fonts-liberation",
        "libnss3",
        "libatk-bridge2.0-0",
        "libdrm2",
        "libxkbcommon0",
        "libgbm1",
        "libasound2t64"
      ]
    },
    "install": {
      "cmds": [
        "PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true npm install",
        "cd client && npm install"
      ]
    },
    "build": {
      "cmds": [
        "cd client && npm run build"
      ]
    }
  },
  "start": {
    "cmd": "node server/index.js"
  }
}

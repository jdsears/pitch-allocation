{
  "name": "morley-pitch-agent",
  "version": "1.0.0",
  "description": "Pitch allocation agent for Morley YFC",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "db:migrate": "node server/db/migrate.js",
    "db:seed": "node server/db/seed.js",
    "scrape": "node scripts/scrape-local.js",
    "scrape:dry": "node scripts/scrape-local.js --dry-run",
    "scrape:boys": "node scripts/scrape-local.js --boys-only",
    "scrape:girls": "node scripts/scrape-local.js --girls-only"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "date-fns": "^3.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "multer": "^2.0.2",
    "node-cron": "^3.0.3",
    "pg": "^8.12.0",
    "puppeteer": "^22.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=20"
  }
}
